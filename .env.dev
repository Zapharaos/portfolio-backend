DJANGO_PORT=8001
DJANGO_DEBUG_MODE=1
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your_secret_key_placeholder

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:$DJANGO_PORT

# --- Optional (defaults shown) ------------------------------------------------

# Per-IP API rate limits (DRF), format <count>/<period>.
# THROTTLE_HEALTH=30/min
# THROTTLE_PROJECTS=60/min
# THROTTLE_USER=60/min

# Project health checks.
# PROJECT_HEALTH_LAZY_REFRESH=true   # re-probe stale projects on GET /projects/health/
# PROJECT_HEALTH_MAX_AGE=600         # TTL (s): re-probe a project at most once per window
# PROJECT_HEALTH_MAX_WORKERS=32      # max concurrent probes per refresh
# PROJECT_HEALTH_CLIENT_TTL=60       # Cache-Control max-age on the health response

# Optional build version, surfaced in GET /health/.
# APP_VERSION=
